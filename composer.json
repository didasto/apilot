{
    "name": "didasto/apilot",
    "description": "A Laravel package for rapid REST API development with model-based CRUD controllers.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Didasto\\Apilot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Didasto\\Apilot\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Didasto\\Apilot\\ApilotServiceProvider"
            ]
        }
    }
}